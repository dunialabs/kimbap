services:
  postgres:
    image: postgres:16-alpine
    # platform: linux/amd64  # 让Docker自动选择合适的架构
    container_name: peta-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: peta
      POSTGRES_PASSWORD: peta123
      POSTGRES_DB: peta_db
    ports:
      - "${PETA_POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U peta -d peta_db"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - peta-network

  cloudflared:
    image: cloudflare/cloudflared:latest
    # platform: linux/amd64  # 让Docker自动选择合适的架构
    container_name: peta-cloudflared
    restart: unless-stopped
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN=${CLOUDFLARE_TUNNEL_TOKEN:-}
    networks:
      - peta-network
    volumes:
      - ./cloudflared:/etc/cloudflared

  peta-console:
    image: petaio/peta-console:latest
    # platform: linux/amd64  # 让Docker自动选择合适的架构
    container_name: peta-console-app
    restart: unless-stopped
    pull_policy: always
    ports:
      - "${PETA_FRONTEND_PORT:-3000}:3000"
      - "${PETA_BACKEND_PORT:-3002}:3002"
    environment:
      DB_HOST: postgres
      DB_PORT: 5432
      DB_USER: peta
      DB_PASSWORD: peta123
      DB_NAME: peta_db
      DATABASE_URL: postgresql://peta:peta123@postgres:5432/peta_db
      NODE_ENV: production
      SKIP_PRISMA_GENERATE: true
    entrypoint: ["/app/docker/docker-entrypoint.sh"]
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - peta-network
    volumes:
      - ./cloudflared:/app/cloudflared

  # Optional: Adminer for database management
  adminer:
    image: adminer:latest
    # platform: linux/amd64  # 让Docker自动选择合适的架构
    container_name: peta-adminer
    restart: unless-stopped
    ports:
      - "${PETA_ADMINER_PORT:-8080}:8080"
    depends_on:
      - postgres
    environment:
      ADMINER_DEFAULT_SERVER: postgres
    networks:
      - peta-network

volumes:
  postgres_data:
    driver: local

networks:
  peta-network:
    driver: bridge