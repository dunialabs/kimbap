/** @type {import('next').NextConfig} */
const nextConfig = {
  // Electron static export config - only enabled in production
  ...(process.env.NODE_ENV === 'production' && { output: 'export' }),

  // Image config - Electron environment requires optimization disabled
  images: {
    unoptimized: true, // Required for Electron environment
    formats: ['image/webp', 'image/avif'],
    minimumCacheTTL: 60,
    dangerouslyAllowSVG: true,
    contentSecurityPolicy: "default-src 'self'; script-src 'none'; sandbox;"
  },

  // Fix build output path issues - only enabled in production
  ...(process.env.NODE_ENV === 'production' && { assetPrefix: './' }),

  // Experimental features and performance tweaks
  experimental: {
    optimizeCss: false, // Must stay off for Electron environment
    optimizePackageImports: ['@radix-ui/react-*', 'lucide-react']
  },

  // TypeScript config - temporarily ignore build errors
  typescript: {
    ignoreBuildErrors: true
  },

  // ESLint config
  eslint: {
    ignoreDuringBuilds: false
  },

  // Enable compression
  compress: true,

  // Enable strict mode
  reactStrictMode: true,

  // Remove Next.js signature
  poweredByHeader: false,

  // Webpack configuration optimizations
  webpack: (config, { dev, isServer }) => {
    // Fallback configuration for Electron environment
    if (!isServer) {
      config.resolve.fallback = {
        ...config.resolve.fallback,
        fs: false,
        net: false,
        tls: false
      }
    }

    // Production optimizations - chunk splitting strategy
    if (!dev && !isServer) {
      config.optimization.splitChunks = {
        chunks: 'all',
        cacheGroups: {
          default: false,
          vendor: {
            name: 'vendor',
            chunks: 'all',
            test: /node_modules/,
            priority: 10
          },
          common: {
            minChunks: 2,
            priority: -10,
            reuseExistingChunk: true
          }
        }
      }
    }

    return config
  }
}

export default nextConfig
