{
  "name": "kimbap-console",
  "version": "1.1.7",
  "private": true,
  "scripts": {
    "dev": "node scripts/setup-database.js && node server.js",
    "dev:quick": "npm run setup-db && next dev",
    "dev:next": "node scripts/setup-database.js && next dev",
    "dev:custom": "node scripts/setup-database.js && node server.js",
    "setup-db": "node scripts/setup-database.js",
    "check-docker": "node scripts/check-docker.js",
    "dev:frontend-only": "echo '\u26a0\ufe0f  Starting without database - you can connect to an external database' && next dev",
    "build": "next build",
    "start": "node scripts/unified-db-init.js && next start",
    "start:custom": "node scripts/unified-db-init.js && NODE_ENV=production node server.js",
    "start:production": "node scripts/unified-db-init.js && next start -p ${PORT:-3000}",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "migrate:backend": "prisma db push",
    "db:stop": "docker compose down",
    "db:restart": "docker compose restart",
    "db:logs": "docker compose logs -f",
    "db:init": "node scripts/unified-db-init.js",
    "db:init:verbose": "DB_INIT_VERBOSE=true node scripts/unified-db-init.js",
    "db:migrate:create": "prisma db push",
    "db:migrate:deploy": "prisma db push",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:adminer": "echo 'Adminer is not used in SQLite mode'",
    "db:reset": "prisma db push --force-reset",
    "db:reset:complete": "node scripts/db-reset-complete.js",
    "test:log-sync": "node -e \"require('./jobs/log-sync.js').syncLogs()\"",
    "test:openapi-parity": "node ./node_modules/tsx/dist/cli.mjs scripts/check-openapi-converter-parity.ts",
    "build:complete": "node scripts/build-standalone-complete.js",
    "build:complete:x64": "node scripts/build-standalone-complete.js x64",
    "build:linux:x64": "node scripts/build-standalone-complete.js x64 linux",
    "build:windows:x64": "node scripts/build-standalone-complete.js x64 win32",
    "build:all": "npm run build:complete:x64 && npm run build:linux:x64 && npm run build:windows:x64",
    "docker:deploy": "./docker-run-with-env.sh",
    "docker:deploy:auto": "./docker-run-with-auto-ports.sh",
    "docker:find-ports": "node scripts/find-available-ports.js",
    "docker:up:auto-ports": "docker compose --env-file .env.ports up -d",
    "docker:build": "docker build -t dunialabs/kimbap-console:latest .",
    "docker:build:amd64": "docker build --platform linux/amd64 -t dunialabs/kimbap-console:latest .",
    "docker:build:multiarch": "docker buildx build --platform linux/amd64,linux/arm64 -t dunialabs/kimbap-console:latest . --push",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:push": "docker push dunialabs/kimbap-console:latest",
    "docker:build:push": "npm run docker:build && npm run docker:push",
    "docker:deploy:full": "npm run docker:build:push && docker compose pull && npm run docker:up",
    "postinstall": "npm run db:generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@prisma/client": "^6.13.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.1.0",
    "input-otp": "1.4.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.4",
    "nodemailer": "^7.0.5",
    "react": "^19",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19",
    "react-hook-form": "^7.54.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.12.7",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.15",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^9.31.0",
    "eslint-config-next": "15.4.2",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "prisma": "^6.13.0",
    "supertest": "^7.1.3",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "wait-on": "^7.2.0"
  }
}
