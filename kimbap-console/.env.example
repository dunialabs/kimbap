 # @FilePath: /peta-console/.env.example
 # @Description: 这是默认设置,请设置`customMade`, 打开koroFileHeader查看配置 进行设置: https://github.com/OBKoro1/koro1FileHeader/wiki/%E9%85%8D%E7%BD%AE
### 
# 数据库连接
DATABASE_URL="postgresql://peta:peta123@localhost:5432/peta_console?schema=public"

# JWT 密钥 (请更换为安全的随机字符串)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# 邮件服务配置 (可选，用于发送验证码)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# 开发环境配置
NODE_ENV="development"

# PETA Core 连接配置 (Priority 2: environment variable)
# Format: http://host:port (without /admin suffix)
# Priority system: 1. Database config > 2. MCP_GATEWAY_URL > 3. Auto-detection
MCP_GATEWAY_URL="http://localhost:3002"

# 日志同步配置
LOG_SYNC_ENABLED="true"                   # 启用/禁用日志同步 (true/false)
LOG_SYNC_INTERVAL_MINUTES="2"            # 日志同步间隔时间(分钟)
MAX_LOGS_PER_REQUEST="5000"              # 每次请求最大日志条数
LOG_BATCH_SIZE="500"                     # 批量保存日志的批次大小
LOG_SYNC_TIMEOUT="180000"                # 日志同步请求超时时间(毫秒)
LOG_SYNC_RETRY_ATTEMPTS="2"              # 日志同步重试次数

# Google Drive OAuth 配置
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# 前端可访问的环境变量（用于构建 MCP 配置）
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET="your-google-client-secret"
# 注意: GOOGLE_REDIRECT_URI 已改为动态配置，使用当前请求的 host + 端口
# 在 Google Cloud Console 配置重定向 URI 时，添加: http://localhost:3000/dashboard/tool-configure 和 https://yourdomain.com/dashboard/tool-configure

LICENSE_MASTER_PASSWORD="PETA-LICENSE-MASTER-PASSWORD-2024"

# Cloudflare Tunnel 配置 (可选 - 用于 HTTPS 远程访问)
# 获取 Token: https://dash.cloudflare.com/ → Zero Trust → Networks → Tunnels → Create tunnel
# 详细说明: 查看 docs/GET_CLOUDFLARE_TOKEN.md
CLOUDFLARE_TUNNEL_TOKEN=""
