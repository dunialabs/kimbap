# =============================================================================
# Kimbap Core Configuration
# =============================================================================

# Database connection
DATABASE_URL=postgresql://kimbap:kimbap123@localhost:5432/kimbap_core?schema=public
AUTO_MIGRATE=true

# JWT secret (must match between Core and Console)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server configuration
BACKEND_PORT=3002

# HTTPS/SSL (optional)
ENABLE_HTTPS=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Server Lazy Loading (default: true)
LAZY_START_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
LOG_RESPONSE_MAX_LENGTH=300

# Docker
KIMBAP_CORE_IN_DOCKER=false

# Skills
SKILLS_DIR=./skills

# Kimbap Cloud API (optional)
KIMBAP_CLOUD_API_URL=

# CORS (comma-separated origins; default: "*" for development)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://console.kimbap.sh

# Multi-replica settings (optional)
# AUTO_CONNECT_ENABLED_SERVERS=true
# SERVER_RECONCILE_INTERVAL_SEC=30
# RUN_CLUSTER_JOBS=true          # Set to false on non-primary replicas

# REST v1 API (enabled by default)
# ENABLE_V1_API=true
