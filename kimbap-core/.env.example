# =============================================================================
# Kimbap Configuration
# =============================================================================
# kimbap uses ~/.kimbap/config.yaml for most configuration.
# See: https://docs.kimbap.dev/configuration
# Environment variables below are used for development overrides.

# Vault master key (required in production; dev mode generates one automatically)
# KIMBAP_MASTER_KEY_HEX=<64 hex chars = 32 bytes>

# Dev mode (auto-generates vault key, relaxes security checks)
# KIMBAP_DEV=true

# Data directory (default: ~/.kimbap)
# KIMBAP_DATA_DIR=

# Log level (debug, info, warn, error)
LOG_LEVEL=info
