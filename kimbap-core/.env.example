# Database connection
DATABASE_URL=postgresql://kimbap:kimbap123@localhost:5432/kimbap_core?schema=public
AUTO_MIGRATE=true

# Environment
NODE_ENV=development

# JWT secret (please change to a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Backend server configuration
BACKEND_PORT=3002

# HTTPS/SSL configuration
ENABLE_HTTPS=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# MCP Server Lazy Loading (default: true)
LAZY_START_ENABLED=true

# Logging configuration
LOG_LEVEL=info
LOG_PRETTY=true
LOG_RESPONSE_MAX_LENGTH=300

# Docker configuration
KIMBAP_CORE_IN_DOCKER=false

# Skills directory
SKILLS_DIR=./skills

# Kimbap Cloud API
KIMBAP_CLOUD_API_URL=
